<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>😇 SAINT OR SINNER 😈</title>
    <style>
        /* Import Fonts */
        @import url('https://fonts.googleapis.com/css2?family=Creepster&family=Cinzel:wght@700&family=Roboto+Mono:wght@500;700&family=Dancing+Script:wght@700&display=swap');
        
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        
        body {
            font-family: 'Roboto Mono', monospace;
            background-color: #1a0a0a;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            color: white;
            overflow-y: auto; 
            transition: background 1.5s ease;
            user-select: none;
        }

        .game-container {
            width: 100%;
            max-width: 500px;
            padding: 15px;
            position: relative;
            overflow-x: hidden;
        }

        /* --- THEMES --- */
        body.devil-theme {
            background: linear-gradient(135deg, #1a0a0a 0%, #2d0a0a 50%, #1a0505 100%);
        }
        body.devil-theme .game-title { color: #ff3333; text-shadow: 0 0 20px #ff0000; }
        body.devil-theme .speaker-box { background: linear-gradient(145deg, #330000, #220000); border: 2px solid #ff4444; color: #ffcccc; box-shadow: 0 0 20px rgba(255,0,0,0.2); }
        body.devil-theme .timer-bar { background: linear-gradient(90deg, #ff0000, #ff6600); box-shadow: 0 0 10px #ff4400; }
        body.devil-theme .question-box { background: linear-gradient(145deg, #2a0a0a, #1a0505); border: 2px solid #ff4444; box-shadow: 0 0 30px rgba(255,0,0,0.1); }
        body.devil-theme .option-btn { background: linear-gradient(145deg, #3a0a0a, #2a0505); border: 2px solid #ff6666; color: white; }
        
        body.angel-theme {
            background: linear-gradient(135deg, #f0f0f0 0%, #ffffff 50%, #e6c200 100%);
            color: #222;
        }
        body.angel-theme .game-title { color: #d4af37; text-shadow: 0 0 20px #ffd700; }
        body.angel-theme .speaker-box { background: linear-gradient(145deg, #fffbe6, #fff); border: 2px solid #d4af37; color: #5c4d00; box-shadow: 0 0 20px rgba(255, 215, 0, 0.4); }
        body.angel-theme .timer-bar { background: linear-gradient(90deg, #d4af37, #ffd700); box-shadow: 0 0 10px #d4af37; }
        body.angel-theme .question-box { background: linear-gradient(145deg, #ffffff, #f0f0f0); border: 2px solid #d4af37; color: #333; box-shadow: 0 0 30px rgba(212, 175, 55, 0.2); }
        body.angel-theme .option-btn { background: white; border: 2px solid #d4af37; color: #333; }

        /* --- TYPOGRAPHY --- */
        .game-title, #screen-error h2, #screen-gameover h2 {
            font-family: 'Creepster', cursive !important;
            font-size: 3.5em; margin-bottom: 10px; text-align: center; line-height: 1; letter-spacing: 2px;
        }

        .main-btn {
            font-family: 'Dancing Script', cursive !important;
            font-size: 1.6em; font-weight: 700; letter-spacing: 1px;
        }

        .question-box { 
            font-family: 'Roboto Mono', monospace; font-size: 1.2em; font-weight: 700; line-height: 1.3;
            padding: 20px; min-height: 100px; display: flex; align-items: center; justify-content: center; text-align: center;
            border-radius: 15px; margin-bottom: 15px;
        }
        
        .option-btn { 
            font-family: 'Roboto Mono', monospace; font-size: 1em; font-weight: 500;
            padding: 16px 20px; margin: 8px 0; width: 100%; text-align: left; border-radius: 10px; 
            cursor: pointer; transition: all 0.2s; position: relative; overflow: hidden;
        }

        .speaker-box {
            font-family: 'Roboto Mono', monospace; font-size: 1.1em;
            border-radius: 20px; padding: 12px 25px; margin-bottom: 15px; 
            position: relative; font-weight: bold; text-align: center;
        }

        /* --- ELEMENTS --- */
        .avatar {
            font-size: 90px; margin: 10px 0 15px 0; display: inline-block;
            animation: floatAvatar 3s ease-in-out infinite; cursor: pointer;
            filter: drop-shadow(0 0 15px rgba(0,0,0,0.5));
        }
        @keyframes floatAvatar { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; flex-wrap: nowrap; }
        
        .lives-container { 
            font-size: 1.5em; 
            letter-spacing: 3px; 
            white-space: nowrap; 
            flex-shrink: 0;
        }
        .life-lost { opacity: 0.3; filter: grayscale(100%); }

        .timer-bar { height: 10px; width: 100%; transition: width 0.1s linear; margin: 15px 0; border-radius: 6px; }

        .option-btn:active { transform: scale(0.98); }
        .option-btn.correct { background: linear-gradient(145deg, #004400, #003300) !important; border-color: #00ff00 !important; color: white !important; }
        .option-btn.wrong { background: linear-gradient(145deg, #440000, #330000) !important; border-color: #ff0000 !important; color: white !important; animation: shake 0.4s; }
        .option-btn.disabled { opacity: 0.4; pointer-events: none; text-decoration: line-through; }

        @keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-5px); } 75% { transform: translateX(5px); } }

        .screen { display: none; text-align: center; padding-bottom: 20px; animation: fadeIn 0.3s; width: 100%; }
        .active { display: block; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

        #screen-error { padding-top: 50px; }
        #screen-error .error-icon { font-size: 80px; margin: 30px 0; display:block; text-shadow: 0 0 20px #ffaa00; animation: pulse 1s infinite;}
        #screen-error p { color: #ccc; font-family: 'Roboto Mono', monospace; font-size: 1.1em; opacity: 0.8; margin-bottom: 40px; }
        
        .main-btn {
            background: linear-gradient(145deg, #cc0000, #990000); border: none; color: white; padding: 15px 30px;
            cursor: pointer; border-radius: 10px; margin: 10px 0; width: 100%; box-shadow: 0 5px 0 #660000;
        }
        .main-btn:active { transform: translateY(3px); box-shadow: 0 2px 0 #660000; }
        
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.95); z-index: 100; display: none; justify-content: center; align-items: center; flex-direction: column; padding: 20px; }
        .modal.open { display: flex; }
        .modal-box { border-radius: 20px; max-width: 90%; text-align: center; padding: 30px; border: 2px solid; transition: all 0.5s; }
        
        .modal-box h2 { font-family: 'Cinzel', serif; margin-bottom: 20px; }
        #screen-result h2, #screen-fail h2 { font-family: 'Cinzel', serif; }

        body.devil-theme .modal-box { background: #1a0505; border-color: #ff4444; color: white; box-shadow: 0 0 50px rgba(255,0,0,0.2); }
        body.devil-theme .modal .main-btn { background: linear-gradient(145deg, #cc0000, #990000); color: white; }
        
        body.angel-theme .modal-box { background: #ffffff; border-color: #d4af37; color: #333; box-shadow: 0 0 50px rgba(212, 175, 55, 0.4); }
        body.angel-theme .modal .main-btn { background: linear-gradient(145deg, #ffd700, #d4af37); color: #333; box-shadow: none; }
        
        .icon-btn {
            background: rgba(0,0,0,0.4); width: 45px; height: 45px; border-radius: 50%;
            display: flex; justify-content: center; align-items: center; cursor: pointer; margin-right: 10px;
            font-size: 1.2em; border: 1px solid rgba(255,255,255,0.2); transition: 0.2s;
            font-family: 'Roboto Mono', monospace; flex-shrink: 0;
        }
        .icon-btn:hover { background: rgba(255,255,255,0.1); }
        body.angel-theme .icon-btn { color: #333; border: 1px solid #d4af37; background: rgba(255,255,255,0.6); }

        .particles { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0; }
        .particle { position: absolute; width: 4px; height: 4px; background: #ff4444; border-radius: 50%; animation: float 10s infinite; opacity: 0.3; }
        body.angel-theme .particle { background: #d4af37; }
        
        .high-score-label {
            font-family: 'Roboto Mono', monospace; color: #ffd700; font-size: 0.9em; 
            margin-bottom: 30px; opacity: 0.9; letter-spacing: 1px;
        }

        /* --- TUTORIAL OVERLAY STYLES (Arrows Removed) --- */
        #tutorial-layer {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.9); z-index: 999; 
            display: none; /* Hidden by default */
            flex-direction: column; justify-content: center; align-items: center;
            font-family: 'Dancing Script', cursive;
        }
        
        /* Positioning text groups to corners */
        .tut-group { position: absolute; color: white; text-align: center; }
        /* Adjusted Top position since arrows are gone */
        .tut-left { top: 90px; left: 15px; text-align: left; }
        .tut-right { top: 90px; right: 15px; text-align: right; }
        
        .tut-text { font-size: 1.2em; margin-top: 5px; text-shadow: 0 0 10px black; }
        .tut-icon { font-family: 'Roboto Mono', monospace; font-size: 1.2em; }

        @media (max-width: 400px) {
            .game-title { font-size: 2.8em !important; }
            .avatar { font-size: 70px !important; margin: 5px 0 !important; }
            .question-box { font-size: 1.1em !important; padding: 15px !important; min-height: 80px !important; }
            .option-btn { font-size: 0.95em !important; padding: 12px 15px !important; }
            .lives-container { font-size: 1.2em !important; letter-spacing: 2px !important; }
            .icon-btn { width: 38px !important; height: 38px !important; font-size: 1em !important; margin-right: 5px !important; }
            .main-btn { font-size: 1.3em !important; padding: 12px 20px !important; }
            .speaker-box { font-size: 1em !important; padding: 10px !important; }
        }
    </style>
</head>
