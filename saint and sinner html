    <script>
        document.addEventListener('DOMContentLoaded', () => {
            initParticles();
            try {
                let saved = localStorage.getItem('devilLearnedDB');
                if (saved) learnedQuestions = JSON.parse(saved);
                updateLearnedCount();
            } catch (e) { learnedQuestions = []; }
            
            const best = localStorage.getItem('devilBestScore') || 0;
            document.getElementById('bestScoreDisplay').textContent = best;
        });

        // --- STATE ---
        let state = {
            mode: 'offline',
            level: 1,
            score: 0,
            lives: 3,
            hints: 3,
            timer: null,
            timeLeft: 100,
            active: false,
            paused: false,
            isAngelRound: false,
            hintUsedInRound: false,
            lastQuestion: null,
            musicOn: false,
            musicTimer: null 
        };

        // --- DATA ---
        const baseQuestions = [
            { text: "2 + 2 = ?", type: "inverse", options: ["4", "5", "22"], truthIndex: 0 },
            { 
                text: "Select the Red Text", 
                type: "trap", 
                options: [
                    {text:"BLUE", color:"#f00", isTruth: true}, 
                    {text:"RED", color:"#00f", isTruth: true},  
                    {text:"GREEN", color:"#0f0", isTruth: false}
                ] 
            }, 
            { text: "Click Me!", type: "wait", timerOverride: 50, options: ["Click Me", "Ok", "yes"] },
            { text: "Is the earth round?", type: "inverse", options: ["Yes", "No", "Maybe"], truthIndex: 0 },
            { text: "Fire is...", type: "inverse", options: ["Hot", "Cold", "Wet"], truthIndex: 0 }
        ];

        let learnedQuestions = [];
        let activeDeck = [];
        let onlineBuffer = [];

        function updateLearnedCount() { 
            const el = document.getElementById('learnedCount');
            if(el) el.textContent = learnedQuestions.length; 
        }

        function learnNewQuestion(qData) {
            const exists = learnedQuestions.some(q => q.text === qData.text);
            if (!exists) {
                const newQ = { text: qData.text, type: 'inverse', options: qData.options, truthIndex: 0 };
                learnedQuestions.push(newQ);
                
                // Keep local storage from exceeding limits
                if (learnedQuestions.length > 200) {
                    learnedQuestions.shift();
                }
                
                localStorage.setItem('devilLearnedDB', JSON.stringify(learnedQuestions));
                updateLearnedCount();
            }
        }

        function initDeck() { activeDeck = [...baseQuestions, ...learnedQuestions]; }

        // --- NEW AMBIENT MUSIC ENGINE (Relaxing) ---
        let audioCtx = null;

        function initAudio() {
            if (!audioCtx) { try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); } catch(e) {} }
            if (audioCtx && audioCtx.state === 'suspended') audioCtx.resume();
        }

        function toggleMusic() {
            initAudio();
            state.musicOn = !state.musicOn;
            const btn = document.getElementById('musicBtn');
            
            if(state.musicOn) {
                btn.style.borderColor = '#00ff00';
                btn.style.color = '#00ff00';
                startAmbientMusic();
            } else {
                btn.style.borderColor = '';
                btn.style.color = '';
                stopAmbientMusic();
            }
        }

        function startAmbientMusic() {
            if(state.musicTimer) clearInterval(state.musicTimer);
            playAmbientNote();
            state.musicTimer = setInterval(playAmbientNote, 3000);
        }

        function stopAmbientMusic() {
            if(state.musicTimer) clearInterval(state.musicTimer);
        }

        function playAmbientNote() {
            if(!audioCtx || !state.musicOn) return;
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            
            osc.connect(gain);
            gain.connect(audioCtx.destination);

            const now = audioCtx.currentTime;
            
            if(state.isAngelRound) {
                osc.type = 'sine';
                const notes = [523.25, 587.33, 659.25, 783.99, 880.00]; 
                osc.frequency.value = notes[Math.floor(Math.random() * notes.length)];
                
                gain.gain.setValueAtTime(0, now);
                gain.gain.linearRampToValueAtTime(0.1, now + 0.1); 
                gain.gain.exponentialRampToValueAtTime(0.001, now + 2); 
                osc.start(now);
                osc.stop(now + 2);
            } else {
                osc.type = 'triangle';
                const notes = [130.81, 146.83, 155.56, 174.61, 196.00];
                osc.frequency.value = notes[Math.floor(Math.random() * notes.length)];

                gain.gain.setValueAtTime(0, now);
                gain.gain.linearRampToValueAtTime(0.05, now + 0.1);
                gain.gain.exponentialRampToValueAtTime(0.001, now + 3); 
                osc.start(now);
                osc.stop(now + 3);
            }
        }

        function playSound(type) {
            if (!audioCtx) return;
            try {
                const o = audioCtx.createOscillator();
                const g = audioCtx.createGain();
                o.connect(g); g.connect(audioCtx.destination);
                if (type === 'correct') {
                    o.frequency.setValueAtTime(600, audioCtx.currentTime);
                    g.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);
                } else {
                    o.frequency.setValueAtTime(100, audioCtx.currentTime);
                    o.type = 'sawtooth';
                    g.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.3);
                }
                o.start(); o.stop(audioCtx.currentTime + 0.3);
            } catch (e) { }
        }

        function showScreen(id) {
            document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
            document.getElementById(id).classList.add('active');
        }
        function showModeSelection() { showScreen('screen-mode'); }
        
        function showModal(id) { 
            state.paused = true;
            document.getElementById(id).classList.add('open'); 
        }
        function closeModals() { 
            state.paused = false;
            document.querySelectorAll('.modal').forEach(m => m.classList.remove('open')); 
        }

        function checkTutorial() {
            if (!localStorage.getItem('tutorialSeen')) {
                document.getElementById('tutorial-layer').style.display = 'flex';
                return true; 
            }
            return false;
        }

        function closeTutorial() {
            localStorage.setItem('tutorialSeen', 'true');
            document.getElementById('tutorial-layer').style.display = 'none';
            loadLevel(); 
        }

        function updateLivesUI() {
            const container = document.getElementById('livesDisplay');
            let html = '';
            for(let i=0; i<3; i++) {
                if(i < state.lives) html += '❤️';
                else html += '<span class="life-lost">💔</span>';
            }
            container.innerHTML = html;
        }

        function setTheme(isAngel) {
            const body = document.getElementById('bodyTheme');
            const avatar = document.getElementById('gameAvatar');
            const speaker = document.getElementById('speakerBox');
            
            if(isAngel) {
                body.className = 'angel-theme';
                avatar.textContent = '😇';
                speaker.textContent = 'Angel says: Tell the TRUTH.';
                document.getElementById('winAvatar').textContent = '😇';
                document.getElementById('winMsg').textContent = 'Truth prevails.';
            } else {
                body.className = 'devil-theme';
                avatar.textContent = '😈';
                speaker.textContent = 'Devil says: Tell the TRUTH.';
                document.getElementById('winAvatar').textContent = '😈';
                document.getElementById('winMsg').textContent = 'Good lie.';
            }
        }

        function useHint() {
            if (state.hints <= 0 || !state.active || state.paused) return;
            
            if (state.hintUsedInRound) {
                document.getElementById('hintBtn').classList.add('shake');
                setTimeout(() => document.getElementById('hintBtn').classList.remove('shake'), 500);
                return;
            }

            if (state.lastQuestion.type === 'wait') {
                alert("Hint: Don't touch anything!");
                state.hintUsedInRound = true;
                return;
            }

            state.hints--;
            state.hintUsedInRound = true; 
            document.getElementById('hintCount').textContent = state.hints;
            document.getElementById('hintBtn').classList.add('used');

            const buttons = document.querySelectorAll('.option-btn:not(.disabled)');
            if (buttons.length <= 1) return;

            for (let btn of buttons) {
                const isTruth = (btn.getAttribute('data-truth') === 'true');
                
                if (state.isAngelRound) {
                    if (!isTruth) { btn.classList.add('disabled'); break; }
                }
                else {
                    if (!isTruth) { btn.classList.add('disabled'); break; }
                }
            }
        }

        function showReview() {
            const content = document.getElementById('reviewContent');
            if (!state.lastQuestion) {
                content.innerHTML = `<h2>LAST ROUND</h2><p>No data.</p><button class="main-btn" onclick="closeModals()">Close</button>`;
            } else {
                const q = state.lastQuestion;
                let html = `<h2>LAST ROUND</h2>`;
                if (q.wasAngel) {
                    html += `<p style="color:#d4af37; font-weight:bold;">😇 ANGEL ROUND</p>`;
                    html += `<p style="font-size:0.9em; opacity:0.8; font-family:'Roboto Mono'">She said: "Tell the Truth."</p>`;
                    html += `<p>You must <b>OBEY</b> (Tell Truth).</p>`;
                } else {
                    html += `<p style="color:#ff4444; font-weight:bold;">😈 DEVIL ROUND</p>`;
                    html += `<p style="font-size:0.9em; opacity:0.8; font-family:'Roboto Mono'">He said: "Tell the Truth."</p>`;
                    html += `<p>You must <b>DISOBEY</b> (Lie).</p>`;
                }
                html += `<hr style="margin:15px 0; border-color:currentColor; opacity:0.3;">`;
                html += `<p style="font-size:1.1em; margin-bottom:10px; font-family:'Roboto Mono'">"${q.question}"</p>`;
                if(q.type === 'wait') {
                    if (q.wasAngel) html += `<p>Correct Action: <b>Click Button</b> (Obey)</p>`;
                    else html += `<p>Correct Action: <b>Wait</b> (Disobey)</p>`;
                } else {
                    html += `<p>Truth was: <b style="opacity:0.8;">${q.truthText}</b></p>`;
                }
                html += `<br><button class="main-btn" onclick="closeModals()">Close</button>`;
                content.innerHTML = html;
            }
            showModal('modal-review');
        }

        function startGame(mode) {
            initAudio(); 
            state.mode = mode;
            state.level = 1;
            state.score = 0;
            state.lives = 3;
            state.hints = 3;
            state.paused = false;
            document.getElementById('hintCount').textContent = state.hints;
            state.lastQuestion = null;
            if(mode === 'offline') initDeck();
            
            showScreen('screen-game');
            updateLivesUI();

            if (!checkTutorial()) {
                loadLevel();
            }
        }

        function restartGame() { startGame(state.mode); }

        function decodeHTML(html) {
            const txt = document.createElement("textarea");
            txt.innerHTML = html;
            return txt.value;
        }

        async function loadLevel() {
            state.active = true;
            state.paused = false;
            state.hintUsedInRound = false; 
            document.getElementById('hintBtn').classList.remove('used');
            
            document.getElementById('levelNum').textContent = state.level;
            document.getElementById('scoreNum').textContent = state.score;
            document.getElementById('optionsContainer').innerHTML = '';
            document.getElementById('questionText').textContent = "Summoning...";

            state.isAngelRound = (state.level % 10 === 0);
            setTheme(state.isAngelRound);

            let data = null;
            try {
                if (state.mode === 'online') {
                    data = await fetchOnlineQuestion();
                } else {
                    data = getOfflineQuestion();
                }
            } catch(e) {
                showScreen('screen-error');
                return;
            }

            let calculatedTruth = "Unknown";
            if (data.type === 'online') calculatedTruth = data.correctAnswer;
            else if (data.type === 'inverse') {
                const truthObj = data.options.find(o => o.isTruth === true);
                if (truthObj) calculatedTruth = truthObj.text;
            }

            state.lastQuestion = {
                question: data.question,
                type: data.type,
                truthText: calculatedTruth,
                wasAngel: state.isAngelRound
            };

            document.getElementById('questionText').innerHTML = data.question;

            data.options.forEach(opt => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                let btnText = "", isTruthVal = false;
                
                if (typeof opt === 'object' && opt.text) {
                    btnText = decodeHTML(opt.text);
                    if(opt.color) btn.style.color = opt.color;
                    if(opt.isTruth !== undefined) isTruthVal = opt.isTruth;
                } else { btnText = decodeHTML(opt); }
                
                if(data.type === 'online') isTruthVal = (btnText === decodeHTML(data.correctAnswer));
                
                btn.textContent = btnText;
                btn.setAttribute('data-truth', isTruthVal); 
                btn.onclick = () => handleAnswer(opt, btn, data);
                document.getElementById('optionsContainer').appendChild(btn);
            });

            startTimer(data.timerOverride || 100, data.type === 'wait');
        }

        function getOfflineQuestion() {
            if (activeDeck.length === 0) initDeck();
            const randomIndex = Math.floor(Math.random() * activeDeck.length);
            const q = activeDeck[randomIndex];
            activeDeck.splice(randomIndex, 1);
            
            let displayOptions = [];
            if (q.type === 'trap' || q.type === 'wait') {
                displayOptions = [...q.options].sort(() => Math.random() - 0.5);
            } else {
                displayOptions = q.options.map((opt, index) => ({
                    text: opt,
                    isTruth: index === q.truthIndex
                })).sort(() => Math.random() - 0.5);
            }
            return { question: q.text, options: displayOptions, type: q.type, timerOverride: q.timerOverride };
        }

        async function fetchOnlineQuestion() {
            if (onlineBuffer.length === 0) {
                const cats = [9, 17, 22];
                const res = await fetch(`https://opentdb.com/api.php?amount=10&difficulty=easy&type=multiple&category=${cats[Math.floor(Math.random()*3)]}`);
                if (!res.ok) throw new Error("Network error");
                const json = await res.json();
                if (!json.results || json.results.length === 0) throw new Error("No data");
                onlineBuffer = json.results;
            }
            
            const q = onlineBuffer.shift(); 
            
            const learnedOpts = [q.correct_answer, ...q.incorrect_answers.slice(0, 2)];
            learnNewQuestion({ text: q.question, options: learnedOpts });

            let displayOpts = [q.correct_answer, ...q.incorrect_answers.slice(0, 2)];
            displayOpts.sort(() => Math.random() - 0.5); 

            return {
                question: q.question,
                options: displayOpts,
                correctAnswer: q.correct_answer,
                type: 'online'
            };
        }

        function startTimer(duration, isWaitLevel) {
            clearInterval(state.timer);
            state.timeLeft = duration;
            const bar = document.getElementById('timerBar');
            
            const interval = isWaitLevel ? 100 : Math.max(50, 100 - (state.level * 2));

            state.timer = setInterval(() => {
                if (state.paused) return; 
                
                state.timeLeft--;
                if(bar) bar.style.width = (state.timeLeft / duration) * 100 + '%';
                
                if (state.timeLeft <= 0) {
                    clearInterval(state.timer);
                    if (isWaitLevel) {
                        if (state.isAngelRound) handleDeath("You waited? The Angel said Click!");
                        else winLevel();
                    } else {
                        handleDeath("Time's up!");
                    }
                }
            }, interval);
        }

        function handleAnswer(selectedOpt, btn, levelData) {
            if (!state.active || state.paused) return;

            if (levelData.type === 'wait') {
                state.active = false;
                clearInterval(state.timer);
                if (state.isAngelRound) winLevel();
                else handleDeath("You obeyed the Devil!");
                return;
            }

            let isTruth = false;
            if (levelData.type === 'online') {
                const decodedSelected = decodeHTML(typeof selectedOpt === 'string' ? selectedOpt : selectedOpt.text);
                const decodedCorrect = decodeHTML(levelData.correctAnswer);
                isTruth = (decodedSelected === decodedCorrect);
            }
            else isTruth = (selectedOpt.isTruth === true);

            let isWin = false;
            if (state.isAngelRound) isWin = isTruth; 
            else isWin = !isTruth; 

            if (isWin) {
                clearInterval(state.timer);
                state.active = false;
                btn.classList.add('correct');
                playSound('correct');
                setTimeout(winLevel, 500);
            } else {
                btn.classList.add('wrong');
                playSound('wrong');
                const cont = document.querySelector('.game-container');
                if(cont) {
                    cont.classList.add('shake');
                    setTimeout(() => cont.classList.remove('shake'), 500);
                }
                setTimeout(() => handleDeath("Wrong choice!"), 500); 
            }
        }

        function handleDeath(reason) {
            state.lives--;
            updateLivesUI();
            
            clearInterval(state.timer);
            state.active = false;

            if (state.lives > 0) {
                document.getElementById('failMsg').textContent = reason;
                document.getElementById('failLives').textContent = state.lives;
                showScreen('screen-fail');
            } else {
                document.getElementById('loseMsg').textContent = reason;
                document.getElementById('finalScore').textContent = state.score;
                document.getElementById('bestScoreOver').textContent = updateHighScore();
                showScreen('screen-gameover');
            }
        }

        function updateHighScore() {
            const currentBest = parseInt(localStorage.getItem('devilBestScore') || 0);
            if (state.score > currentBest) {
                localStorage.setItem('devilBestScore', state.score);
                document.getElementById('bestScoreDisplay').textContent = state.score;
                return state.score;
            }
            return currentBest;
        }

        function winLevel() {
            state.score += 100 + state.timeLeft;
            showScreen('screen-result');
        }
        function nextLevel() {
            state.level++;
            showScreen('screen-game');
            loadLevel();
        }

        function initParticles() {
            const pc = document.getElementById('particles');
            if(!pc) return;
            for(let i=0; i<20; i++) {
                let d = document.createElement('div');
                d.className = 'particle';
                d.style.left = Math.random()*100+'%';
                d.style.animationDelay = Math.random()*5+'s';
                pc.appendChild(d);
            }
        }
    </script>
</body>
